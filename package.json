{
  "name": "flowy-api",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build src/server.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "test": "bun test",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:studio": "bunx --bun prisma studio ",
    "db:generate": "bunx --bun prisma generate",
    "prepare": "husky",
    "test:unit": "bun test ./src/use-cases",
    "test:e2e": "bun test ./src/http/controllers --preload ./src/test/setup-e2e.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.13",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@react-email/components": "^1.0.6",
    "@react-email/render": "^2.0.4",
    "better-auth": "^1.4.10",
    "elysia": "^1.4.21",
    "nodemailer": "^7.0.12",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/nodemailer": "^7.0.5",
    "bun-types": "^1.3.5",
    "husky": "^9.1.7",
    "prisma": "^7.2.0",
    "ultracite": "7.0.11"
  },
  "module": "src/index.js"
}
